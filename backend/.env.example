# Database (Neon Postgres)
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxxxx.us-east-2.aws.neon.tech/bytestream?sslmode=require
SPRING_DATASOURCE_USERNAME=your_neon_username
SPRING_DATASOURCE_PASSWORD=your_neon_password

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET=your_bucket_name
R2_PUBLIC_URL=https://your-bucket.your-account-id.r2.dev

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
